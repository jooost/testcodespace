{
  "name": "MovieTracker Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/microsoft/codespace-features/external-repository:latest": {
      "cloneUrl": "https://mindchill@dev.azure.com/mindchill/MovieTracker/_git/MovieTracker",
      "folder": "/workspaces/ado-repos"
    },
    "ghcr.io/prulloac/devcontainer-features/pre-commit:1.0.3": {}
  },
  "workspaceFolder": "/workspaces/ado-repos",
  "initializeCommand": "mkdir -p ${localWorkspaceFolder}/../ado-repos",
  "postCreateCommand": "npm install -g azure-functions-core-tools@4 --unsafe-perm true && mkdir -p /workspaces/azurite",
  "postStartCommand": "external-git clone",
  "postAttachCommand": "external-git config",
  "forwardPorts": [10000],
  "portsAttributes": {
    "10000": { "label": "Azurite Blob" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-azuretools.vscode-azurefunctions",
        "Azurite.azurite"
      ],
      "settings": {
        "azurite.location": "/workspaces/azurite",
        "azurite.blobHost": "0.0.0.0"
      }
    }
  }
}
